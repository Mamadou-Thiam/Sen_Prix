# Backend Environment Variables
# Copiez ce fichier vers .env et configurez vos valeurs

# Server
PORT=5000
NODE_ENV=development

# MongoDB
# Pour MongoDB local:
MONGODB_URI=mongodb://localhost:27017/senprix
# Pour MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/senprix?retryWrites=true&w=majority

# JWT
# Générez une clé secrète forte (ex: openssl rand -base64 32)
JWT_SECRET=votre_secret_jwt_super_securise
JWT_EXPIRE=7d
