# Backend Environment Variables
# Copiez ce fichier vers .env et configurez vos valeurs

# Server
PORT=5000
NODE_ENV=production

# MongoDB (OBLIGATOIRE)
# Format: mongodb+srv://username:password@cluster.mongodb.net/database
MONGODB_URI=

# JWT (OBLIGATOIRE - générez avec: openssl rand -base64 32)
JWT_SECRET=
JWT_EXPIRE=7d
